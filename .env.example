# =============================================================================
# AzurePilot Configuration
# =============================================================================

# --- Mode ---
# Set to "demo" for fully offline demo mode (no Azure credentials required)
# Set to "live" for real Azure integration
AZUREPILOT_MODE=demo

# --- Azure Auth (required for live mode) ---
# AzurePilot uses DefaultAzureCredential which supports:
#   1. Managed Identity (when running in Azure)
#   2. Service Principal (via the vars below)
#   3. Azure CLI login (for local development: run `az login`)
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=

# --- Azure Subscription / Scope ---
AZURE_SUBSCRIPTION_ID=
AZURE_RESOURCE_GROUP=          # Optional: scope to a specific resource group

# --- LLM Provider (optional — falls back to mock summarizer if not set) ---
# Azure OpenAI (preferred)
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_DEPLOYMENT=gpt-4o
AZURE_OPENAI_API_VERSION=2024-02-15-preview

# OpenAI fallback (if Azure OpenAI not configured)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# --- API Server ---
API_HOST=0.0.0.0
API_PORT=8000

# --- Metrics Ingestion ---
# Time window for metric analysis (hours)
METRICS_LOOKBACK_HOURS=24
# Metric polling interval (minutes)
METRICS_POLL_INTERVAL_MINUTES=5
